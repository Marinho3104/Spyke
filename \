
/** INCLUDES **/
#include "opencl_wrapper.h"
#include <CL/cl.h>
#include <iostream>


bool spyke::gpu_management::opencl_wrapper::check_opencl_status( int32_t& status, const char*& function_name, const char*&& api_function_name ) {

  if ( status != CL_SUCCESS ) {
  
    std::cout << function_name << " error in " << api_function_name << "with code: " << status << std::endl;

  }

  return 0; 

}
