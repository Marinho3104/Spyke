// Holds all Transaction data decomposed
struct Transaction {

  unsigned char from[ 32 ], to[ 32 ];   
  unsigned long long balance, nonce;

};

// Forward
struct Transaction decompose_transaction_data( __global void*, unsigned int );
bool check_addresses_integrity( unsigned char[ 32 ], unsigned char[ 32 ] );
bool check_balance_nonce();
void check_signature();


kernel void transaction_processing(
    // Balance pool related variables
    __global void* balance_pool, __global char* balance_pool_locker,
    // Transaction data to confirmed
    __global void* transaction_data, unsigned int transaction_data_size
  ) {

    // Decompose the given transaction data
    struct Transaction transaction_decomposed = decompose_transaction_data( transaction_data, transaction_data_size );

    // Local variables used to verify if all checks were succefull
    __local bool check0, check1;

    switch( get_local_id( 0 ) ) {
  
      case 0: check0 = check_addresses_integrity( transaction_decompose.from, transaction_decompose.to ); break;
      case 1: check1 = check_balance_nonce(); break;
      case 2: check_signature(); break;

    }

    for( int _ = 0; _ < 32; _ ++ ) printf("%d", ( int ) transaction_decomposed.from[ _ ]);
    for( int _ = 0; _ < 32; _ ++ ) printf("%d", ( int ) transaction_decomposed.to[ _ ]);

}

// Decompose a given transaction data into a struct with
// all the elements
struct Transaction decompose_transaction_data( __global void* transaction_data, unsigned int transaction_data_size ) {

  struct Transaction transaction_decomposed;
  
  for( int _ = 0; _ < 32; _ ++ ) transaction_decomposed.from[ _ ] = *( ( __global unsigned char* ) transaction_data ++ );
  for( int _ = 0; _ < 32; _ ++ ) transaction_decomposed.to[ _ ] = *( ( __global unsigned char* ) transaction_data ++ );

  // transaction_decomposed.balance = *( ( __global unsigned long long* ) transaction_data ++ );
  // transaction_decomposed.nonce = *( ( __global unsigned long long* ) transaction_data ++ );

  return transaction_decomposed;

}

